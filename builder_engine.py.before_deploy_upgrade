from pathlib import Path
import json

BASE = Path("/root/workspaces/customers")

def create_customer_bot(bot_type: str, bot_name: str):
    bot_name = bot_name.strip().lower().replace(" ", "_")
    bot_type = bot_type.strip().lower()

    project = BASE / bot_name
    (project / "data").mkdir(parents=True, exist_ok=True)
    (project / "logs").mkdir(parents=True, exist_ok=True)
    (project / "backups").mkdir(parents=True, exist_ok=True)

    (project / "requirements.txt").write_text(
        "python-telegram-bot==21.6\npython-dotenv==1.0.1\nopenai\n",
        encoding="utf-8"
    )

    (project / ".env.example").write_text(
        "BOT_TOKEN=put_customer_bot_token_here\nOPENAI_API_KEY=optional_openai_key_here\n",
        encoding="utf-8"
    )

    data = {
        "bot_name": bot_name,
        "bot_type": bot_type,
        "business_name": "",
        "products": [],
        "services": [],
        "prices": [],
        "faq": []
    }

    (project / "data" / "business.json").write_text(
        json.dumps(data, indent=2),
        encoding="utf-8"
    )

    (project / "README.md").write_text(
        f"# {bot_name}\n\nType: {bot_type}\nGenerated by Sameer AI Manager.\n",
        encoding="utf-8"
    )

    (project / "bot.py").write_text(
        f'print("Customer bot {bot_name} ready")\n',
        encoding="utf-8"
    )

    return str(project)
