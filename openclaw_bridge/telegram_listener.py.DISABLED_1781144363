def deepseek_reply(text):
    key = os.getenv("DEEPSEEK_API_KEY")
    if not key:
        for f in ["/root/sameer_ai_manager/.env", "/root/.openclaw/.env", "/root/.openclaw/openclaw.env"]:
            if os.path.exists(f):
                for line in open(f, errors="ignore"):
                    if line.startswith("DEEPSEEK_API_KEY="):
                        key=line.split("=",1)[1].strip().strip('"').strip("'")
                        break
            if key:
                break
    if not key:
        return "DeepSeek API key nahi mili bro. .env me DEEPSEEK_API_KEY set karo."

    data=json.dumps({
        "model":"deepseek-chat",
        "messages":[
            {"role":"system","content":"You are Sameer OpenClaw Operator. You are an AI Operator, not a generic chatbot. Use MEMORY below as source of truth, use Hinglish, never invent evidence. Normal chat is not shell. MEMORY:\n"+read_memory()},
            {"role":"user","content":text}
        ],
        "max_tokens":350,
        "temperature":0.4
    }).encode()

    req=urllib.request.Request(
        "https://api.deepseek.com/v1/chat/completions",
        data=data,
        headers={"Authorization":"Bearer "+key, "Content-Type":"application/json"}
    )
    try:
        with urllib.request.urlopen(req, timeout=25) as r:
            j=json.loads(r.read())
        return j["choices"][0]["message"]["content"].strip()
    except Exception as e:
        return "DeepSeek error: "+str(e)[:300]


