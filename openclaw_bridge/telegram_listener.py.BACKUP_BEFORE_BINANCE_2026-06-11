def read_memory():
    base="/root/.openclaw/workspace/memory_core"
    parts=[]
    for name in ["MASTER_MEMORY.md","PROJECT_REGISTRY.md","CURRENT_STATUS.md","LESSONS_LEARNED.md","KNOWN_BOTS.md"]:
        f=os.path.join(base,name)
        if os.path.exists(f):
            try:
                parts.append(f"\n--- {name} ---\n"+open(f,errors="ignore").read()[:3500])
            except Exception:
                pass
    return "\n".join(parts)[:12000]

