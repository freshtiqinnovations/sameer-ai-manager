# --- CLEAN_AI_ROUTER_GUARD START ---
def should_execute_as_shell(text_input):
    clean = str(text_input).strip().lower()
    if not clean: return False
    # Only these exact words are allowed to trigger terminal subprocess
    allowed_cmds = ['pwd', 'df', 'free', 'systemctl', 'ls', 'top', 'uptime', 'id']
    first_word = clean.split()[0]
    # If it's a long sentence or doesn't start with allowed commands, DO NOT RUN IN SHELL
    if first_word not in allowed_cmds or len(clean.split()) > 4:
        return False
    return True
# --- CLEAN_AI_ROUTER_GUARD END ---

# --- SMART_CONVERSATION_FILTER START ---
def is_valid_terminal_command(text_input):
    clean_text = str(text_input).strip().lower()
    allowed = ['pwd', 'df', 'free', 'systemctl', 'ls', 'top', 'uptime', 'ifconfig']
    if not clean_text: return False
    first_word = clean_text.split()[0]
    if first_word in allowed and len(clean_text.split()) <= 4:
        return True
    return False
# --- SMART_CONVERSATION_FILTER END ---
